interval_seconds: 60
spray_duration: 3
video_duration: 30

gpio_pin: 17
relay_active_high: true

# Status LED on a separate GPIO pin (anode → pin, cathode → ground). The LED
# heartbeat-blinks every 10s while the service is running, blinks 1.5s when
# a frame is captured, and rapid-blinks 5 times on a positive bird detection.
status_led_enabled: true
status_led_pin: 24

# Manual trigger button (momentary switch contacts → pin + ground; uses the
# Pi's internal pull-up). While held, the status LED stays on. On release,
# the service runs the same flow as a real bird detection: capture frame,
# spray, record, upload.
trigger_button_enabled: true
trigger_button_pin: 23

capture_dir: ./captures

# Any OpenRouter model with vision support works here. Examples:
#   anthropic/claude-haiku-4.5    (default — fast + cheap)
#   anthropic/claude-sonnet-4.5   (more accurate on edge cases)
#   openai/gpt-4o-mini            (fallback)
#   google/gemini-2.5-flash       (fallback)
detector_model: anthropic/claude-haiku-4.5
detector_base_url: https://openrouter.ai/api/v1

# System prompt sent to the vision model. The model receives this plus a single
# image and is expected to reply with exactly "yes" or "no". Keep instructions
# short and unambiguous — long prompts cost more per call and don't necessarily
# improve accuracy. See the README "Tuning the prompt" section for guidance.
detector_prompt: |
  You are a bird detector for a backyard pool. Respond with exactly 'yes'
  if you see one or more birds in, on, or near the pool (including birds
  in flight directly above it). Respond with exactly 'no' otherwise.
  Output only the single word.

# Local frame-diff gate. The vision API is only called when the mean per-pixel
# delta between consecutive frames (downscaled grayscale) is >= threshold.
# Tune threshold up if wind/clouds/sun create false positives, down if small
# birds get missed. 0-255 scale; 5 is a reasonable starting point.
motion_enabled: true
motion_threshold: 5.0
motion_downscale: 320

# Only run detection between 07:00 and 19:00 local time. Default true to
# avoid burning API tokens on dark frames at night. Set false for testing
# or if your setup actually needs nighttime coverage (IR camera, etc).
daytime_only: true

# Cloudflare R2 publishing (optional). When enabled, each detection's
# snapshot + event video are uploaded to a bucket so they're viewable
# from anywhere. Setup: create an R2 bucket, enable its public r2.dev
# subdomain, create an "Object Read & Write"-scoped API token, and put
# R2_ACCESS_KEY_ID / R2_SECRET_ACCESS_KEY into .env.
r2_enabled: false
r2_account_id: ""           # from R2 dashboard (the long hex string)
r2_bucket: ""               # bucket name, e.g. bird-away
r2_public_base_url: ""      # e.g. https://pub-<hash>.r2.dev
r2_key_prefix: events       # objects land at <prefix>/YYYY-MM-DD/<file>

log_level: INFO
